{
  "name": "workspace-addons-lab",
  "version": "0.1.0",
  "private": true,
  "description": "A Next.js catalog and Apps Script workspace for Google Workspace add-ons.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:addon": "cross-env NEXT_PUBLIC_PLUGIN_APPTYPE=addon next dev --turbopack",
    "dev:drive": "cross-env NEXT_PUBLIC_PLUGIN_APPTYPE=drive next dev --turbopack",
    "build": "next build",
    "build:addon": "cross-env NEXT_PUBLIC_PLUGIN_APPTYPE=addon next build",
    "build:drive": "cross-env NEXT_PUBLIC_PLUGIN_APPTYPE=drive next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/verify-image-markup-contracts.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "clasp": "clasp"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@neondatabase/serverless": "^1.1.0",
    "antd": "^6.5.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@google/clasp": "3.3.0",
    "@types/google-apps-script": "^2.0.11",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "typescript": "^6.0.3"
  }
}
